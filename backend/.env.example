# =============================================================================
# TechAssassin Backend - Live Environment Configuration
# =============================================================================
# 
# IMPORTANT: 
# - Copy this file to .env.local for local development
# - Update DATABASE_URL with your PostgreSQL connection from pgAdmin 4
# - Ensure PostgreSQL is running locally with TechAssassin database
#
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (Local pgAdmin 4)
# -----------------------------------------------------------------------------
# Get connection details from pgAdmin 4: Server > Properties > Connection
#
# Format: postgresql://username:password@localhost:5432/database_name
# Example: postgresql://techassassin_app:secure_password_123@localhost:5432/techassassin
#
# PRODUCTION: Use your production PostgreSQL connection
# DEVELOPMENT: Use local pgAdmin 4 PostgreSQL connection
# 
DATABASE_URL=postgresql://techassassin_app:secure_password_123@localhost:5432/techassassin

# Alternative format (if you prefer individual settings)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techassassin
DB_USER=techassassin_app
DB_PASSWORD=secure_password_123

# -----------------------------------------------------------------------------
# Supabase Configuration (Optional - for additional features)
# -----------------------------------------------------------------------------
# Get these values from: Supabase Dashboard > Settings > API
#
# If you want to use Supabase alongside local PostgreSQL:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Email Configuration (Live Email Service)
# -----------------------------------------------------------------------------
# Get your API key from: Resend Dashboard > API Keys
#
# Format: re_xxxxxxxxxxxxx
RESEND_API_KEY=re_4HAaBgfq_3Wa11vydZePeXbU1NAEuLHGz

# Email configuration for OTP
RESEND_FROM_EMAIL=noreply@techassassin.com
RESEND_FROM_NAME=TechAssassin

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_RESEND_COOLDOWN_SECONDS=60

# Email templates
OTP_PASSWORD_RESET_TEMPLATE=password-reset
OTP_LOGIN_VERIFICATION_TEMPLATE=login-verification
OTP_EMAIL_VERIFICATION_TEMPLATE=email-verification

# Email styling options
EMAIL_PRIMARY_COLOR=#2563eb
EMAIL_SECONDARY_COLOR=#f59e0b
EMAIL_BACKGROUND_COLOR=#ffffff
EMAIL_BORDER_COLOR=#e2e8f0

# Email delivery options
EMAIL_DELIVERY_METHOD=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true

# Rate limiting for emails
EMAIL_RATE_LIMIT_PER_MINUTE=10
EMAIL_RATE_LIMIT_PER_HOUR=100

# Email analytics
EMAIL_TRACKING_ENABLED=true
EMAIL_OPEN_TRACKING=true
EMAIL_CLICK_TRACKING=true

# Security options
EMAIL_ENCRYPTION=true
EMAIL_DKIM_ENABLED=true
EMAIL_SPF_ENABLED=true

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Base URL of your application (used for email links, redirects, etc.)
#
# PRODUCTION: https://yourdomain.com
# STAGING: https://staging.yourdomain.com or Vercel preview URL
# DEVELOPMENT: http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Environment mode
NODE_ENV=development

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Live Database Configuration
# -----------------------------------------------------------------------------
# Enable live database features
LIVE_DATABASE_ENABLED=true
DATABASE_CONNECTION_POOL_SIZE=10
DATABASE_TIMEOUT_MS=30000

# Enable real-time subscriptions
REALTIME_ENABLED=true
REALTIME_SUBSCRIPTIONS=true

# Database logging
DATABASE_LOGGING=true
DATABASE_QUERY_LOGGING=false

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Session configuration
SESSION_SECRET=your_session_secret_key_here
SESSION_MAX_AGE=604800000

# API security
API_RATE_LIMIT_ENABLED=true
API_REQUEST_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Development vs Production
# -----------------------------------------------------------------------------
# Set to false for production deployment
DEBUG_MODE=false
VERBOSE_LOGGING=false

# Enable hot reload in development
HOT_RELOAD=true

# -----------------------------------------------------------------------------
# Production Deployment Checklist
# -----------------------------------------------------------------------------
# Before deploying to production, ensure:
# 
# ✅ PostgreSQL database created with complete schema
# ✅ All database migrations applied (20260213000001_complete_database_schema.sql)
# ✅ pgAdmin 4 connection tested and working
# ✅ Environment variables set correctly
# ✅ Email service (Resend) configured and tested
# ✅ CORS configured for your frontend domain
# ✅ Security settings updated for production
# ✅ Rate limiting enabled
# ✅ Database backups configured
# ✅ Monitoring and alerts configured
#
# pgAdmin 4 Setup Steps:
# 1. Open pgAdmin 4 at http://localhost:8080
# 2. Create new server connection to localhost:5432
# 3. Create database named "techassassin"
# 4. Run the complete schema migration
# 5. Create application user "techassassin_app"
# 6. Grant necessary permissions
# 7. Update DATABASE_URL in this file
# 8. Test connection with your application
# -----------------------------------------------------------------------------
