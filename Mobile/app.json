{
  "expo": {
    "name": "Tech Assassin",
    "slug": "tech-assassin-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f12"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive_icon.png",
        "backgroundColor": "#0d0f12"
      },
      "package": "com.techassassin.community",
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "backgroundColor": "#0d0f12",
        "barStyle": "light-content"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "a79bb8b3-d975-49f8-a7fc-5316710408d4"
      }
    }
  }
}
